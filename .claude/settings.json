{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/pre-push-hook.js",
            "timeout": 120,
            "statusMessage": "Running pre-push checks (tests + link checker)..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/post-push-hook.js",
            "timeout": 180,
            "statusMessage": "Verifying GitHub Pages deployment..."
          }
        ]
      }
    ]
  }
}
